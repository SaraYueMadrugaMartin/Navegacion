<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Pr02_SaraYueMadrugaMartin.MainPage">

    <Grid>
        <Image Source="img_backgorund.jpg"
               Aspect="AspectFill"
               Opacity="0.9" />

        <VerticalStackLayout Padding="30,100,30,30"
                             Spacing="150"
                             VerticalOptions="Start">

            <!-- Texto de bienvenida con el nombre que haya puesto el usuario. -->
            <Label Text="{Binding WelcomeText}"
                   FontSize="{DynamicResource FontTitle}"
                   HorizontalOptions="Center" />

            <!-- Boton de Ajustes. -->
            <Button x:Name="Ajustes"
                    Text="Ajustes"
                    BackgroundColor="#70FAE4E1"
                    Clicked="SettingsClicked" />
        </VerticalStackLayout>
        
    </Grid>

</ContentPage>
