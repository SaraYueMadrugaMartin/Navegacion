<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Pr02_SaraYueMadrugaMartin"
             x:Class="Pr02_SaraYueMadrugaMartin.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Tipografia fuente -->
            <x:String x:Key="AppFontFamily">Arial</x:String>

            <!-- Tamaño fuente -->
            <x:Double x:Key="FontTitle">32</x:Double>
            <x:Double x:Key="FontSubtitle">22</x:Double>
            <x:Double x:Key="FontBody">16</x:Double>

            <!-- Color fuente-->
            <Color x:Key="ColorDarkMode">White</Color>
            <Color x:Key="ColorLightMode">Black</Color>

        </ResourceDictionary>
    </Application.Resources>
</Application>
