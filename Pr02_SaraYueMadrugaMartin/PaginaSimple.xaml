<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Pr02_SaraYueMadrugaMartin.PaginaSimple"
             Title="Información">
    
    <!-- Pagina dinamica para mostrar la informacion de cada raza de caballo que quiera ver el usuario. -->
    
    <VerticalStackLayout>
        <!-- Propiedad del nombre. -->
        <Label 
            Text="{Binding nombre}"
            VerticalOptions="Center"
            HorizontalOptions="Center" />
        <!-- Propiedad de imagen. -->
        <Image
            Source="{Binding imagen}"
            HeightRequest="185"
            Aspect="AspectFit" />
        <!-- Propiedad de la familia. -->
        <Label
            Text="{Binding familia}"
            VerticalOptions="Center"
            HorizontalOptions="Center" />
    </VerticalStackLayout>
</ContentPage>