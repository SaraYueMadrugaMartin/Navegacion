<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Pr02_SaraYueMadrugaMartin.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Pr02_SaraYueMadrugaMartin"
    Shell.FlyoutBehavior="Flyout"
    Title="Pr02_SaraYueMadrugaMartin">

    <FlyoutItem
        Title="Home">
        <ShellContent
            Title="Home"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage" />
    </FlyoutItem>

    <FlyoutItem
        Title="Page1">
        <ShellContent
            Title="Home"
            ContentTemplate="{DataTemplate local:NewPage1}"
            Route="MainPage" />        
    </FlyoutItem>

</Shell>
